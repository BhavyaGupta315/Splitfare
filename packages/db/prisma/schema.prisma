generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  googleId  String   @unique
  email     String   @unique
  name      String
  createdAt DateTime @default(now())

  createdGroups Group[]        @relation("GroupCreator")
  memberships   Membership[]
  paidExpenses  Expense[]      @relation("ExpensePayer")
  splits        ExpenseSplit[]
  settlementsFrom Settlement[] @relation("SettlementFrom")
  settlementsTo   Settlement[] @relation("SettlementTo")
}

model Group {
  id        String   @id @default(uuid())
  name      String
  createdBy String
  createdAt DateTime @default(now())

  creator     User         @relation("GroupCreator", fields: [createdBy], references: [id])
  members     Membership[]
  expenses    Expense[]
  settlements Settlement[]
}

model Membership {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

enum SplitType {
  EQUAL
  EXACT
  PERCENT
}

model Expense {
  id          String    @id @default(uuid())
  groupId     String
  paidBy      String
  amount      Float
  currency    String    @default("INR")
  description String
  splitType   SplitType @default(EQUAL)
  createdAt   DateTime  @default(now())

  group  Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer  User           @relation("ExpensePayer", fields: [paidBy], references: [id])
  splits ExpenseSplit[]
}

model ExpenseSplit {
  id        String  @id @default(uuid())
  expenseId String
  userId    String
  amount    Float
  settled   Boolean @default(false)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

model Settlement {
  id        String   @id @default(uuid())
  groupId   String
  fromUser  String
  toUser    String
  amount    Float
  settledAt DateTime @default(now())

  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender   User  @relation("SettlementFrom", fields: [fromUser], references: [id])
  receiver User  @relation("SettlementTo", fields: [toUser], references: [id])
}
