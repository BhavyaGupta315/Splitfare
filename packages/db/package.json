{
  "name": "@splitfare/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "node --env-file=../../.env ../../node_modules/.bin/prisma generate",
    "migrate": "node --env-file=../../.env ../../node_modules/.bin/prisma migrate dev",
    "push": "node --env-file=../../.env ../../node_modules/.bin/prisma db push",
    "studio": "node --env-file=../../.env ../../node_modules/.bin/prisma studio",
    "push:test": "node --env-file=../../.env.test ../../node_modules/.bin/prisma db push --force-reset",
    "migrate:test": "node --env-file=../../.env.test ../../node_modules/.bin/prisma migrate deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.7.0"
  }
}
