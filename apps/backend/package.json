{
  "name": "@splitfare/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "dotenv -f ../../.env run -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -f ../../.env run -- node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@splitfare/db": "workspace:*",
    "@splitfare/types": "workspace:*",
    "@splitfare/utils": "workspace:*",
    "@splitfare/validation": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "google-auth-library": "^9.14.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express-serve-static-core": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
