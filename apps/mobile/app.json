{
  "expo": {
    "name": "SplitFare",
    "slug": "splitfare",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "splitfare",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.splitfare.app"
    },
    "android": {
      "package": "com.splitfare.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
